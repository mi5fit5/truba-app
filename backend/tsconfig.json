{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "typeRoots": ["./node_modules/@types", "./src"],
    "types": ["jest", "node"]
  },
  "include": ["src/**/*.ts", "src/global.d.ts", "src/tests/**/*"],
  "exclude": ["node_modules"],
  "ts-node": {
    "files": true
  }
}